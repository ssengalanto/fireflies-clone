# Required. Server-only — NEVER prefix with NEXT_PUBLIC_, which would inline
# the value into the client bundle at build time. The key is read once inside
# app/api/claude/route.ts and never proxied through any other module.
ANTHROPIC_API_KEY=

# Required for automatic transcription (feature 002). Server-only — NEVER
# prefix with NEXT_PUBLIC_. The key is read once inside
# app/api/transcribe/route.ts and never proxied through any other module.
OPENAI_API_KEY=

# Optional. Cosmetic; shown in the document title via app/layout.tsx.
NEXT_PUBLIC_APP_NAME=Fireflies Clone

# Optional. When both BASIC_AUTH_USER and BASIC_AUTH_PASSWORD are set, the
# entire app (UI + API routes) is gated behind HTTP Basic Auth via
# middleware.ts. Intended for public Vercel deployments to keep the
# ANTHROPIC_API_KEY and OPENAI_API_KEY routes from being abused. Leave both
# unset in local dev to disable the gate. Server-only — NEVER prefix with
# NEXT_PUBLIC_.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
